generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id          String       @id @default(cuid())
  name        String
  section     String
  teacherName String?
  enrollments Enrollment[]
  attendances Attendance[]
  feePayments FeePayment[]
  results     Result[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Student {
  id          String       @id @default(cuid())
  name        String
  age         Int
  email       String       @unique
  phone       String?
  enrollments Enrollment[]
  attendanceRecords AttendanceRecord[]
  feePayments FeePayment[]
  results Result[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  status    String   @default("active")
  student   Student  @relation(fields: [studentId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id          String  @id @default(cuid())
  classId     String
  date        String //Storing as ISO string or YYYY-MM-DD
  class       Class   @relation(fields: [classId], references: [id])
  records     AttendanceRecord[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([classId, date]) //Ensure only one attendance list exists per class per day
}

model AttendanceRecord {
  id            String @id @default(cuid())
  attendanceId  String
  studentId     String
  status        String //"present"|"absent"|"late"
  attendance    Attendance @relation(fields:[attendanceId], references: [id], onDelete: Cascade)
  student       Student   @relation(fields: [studentId], references: [id])
}

model FeePayment {
  id        String @id @default(cuid())
  studentId String
  classId   String
  amount    Float
  month     String // e.g.. , "January"
  status    String  @default("paid") //"paid" | "pending"
  student   Student @relation(fields: [studentId], references: [id])
  class     Class   @relation(fields:[classId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Result {
  id        String @id @default(cuid())
  studentId String
  classId   String
  subject   String
  marks     Int
  student   Student @relation(fields: [studentId], references : [id])
  class     Class @relation(fields: [classId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt

}